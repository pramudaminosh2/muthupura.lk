rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to upload to their own vehicle folder
    match /vehicles/{userId}/{allPaths=**} {
      // Only authenticated users can write to their own folder
      allow write: if request.auth.uid == userId;
      // Anyone can read (for image CDN delivery)
      allow read: if true;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
